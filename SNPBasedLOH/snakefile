#import pandas df
import pandas as pd

#read in samples, reference, chromosomes
#samp_df = pd.read_csv("./data/testSampleIndex.tsv", sep='\t') 
samp_df = pd.read_csv("./data/sampleIndex.tsv", sep='\t') 
samp_df_hifi = pd.read_csv("./data/sampleIndexHiFi.tsv", sep='\t') 
sampPH_df = pd.read_csv("./data/sampleIndexParHyb.tsv", sep='\t') 
sampP_df = pd.read_csv("./data/sampleIndexPar.tsv", sep='\t') 
ref_df = pd.read_csv("./data/refInfo.tsv", sep="\t")
chr_df = pd.read_csv("./data/chrIndex.tsv", sep="\t")
filtCut_df = pd.read_csv("./data/filterCutoffs.tsv", sep="\t")

#set ref species and annotation path
refSpecies = ["LM"]
refGFF = "data/funcAnnotate/eMapperOut/funcAnnotatePFor.emapper.decorated.gff"

#append samp_df and samp_df_hifi to create samp_df_all
samp_df_all=pd.concat([samp_df,samp_df_hifi],axis=0)

#creating new df for combined cutoffs + chrs
#initialize vectors to store
filtCutPar=[]
filtCutChrs=[]
filtCutGQ=[]
filtCutDP=[]

#create separate group of rows for each 
for i in refSpecies:
    for j in chr_df["CHR"]:
        for k in range(0,len(filtCut_df)):
            filtCutPar.append(i)
            filtCutChrs.append(j)
            filtCutGQ.append(filtCut_df["GQ"][k])
            filtCutDP.append(filtCut_df["DP"][k])
    
#append to create new df
filtCutFinal_df=pd.DataFrame({"PARENTS": filtCutPar, "CHR": filtCutChrs, "GQ": filtCutGQ, "DP": filtCutDP})  

rule all:
    input:
        expand("output/LOHRegions/{chr}LOHRegions_GQ{gqcut}_DP{dpcut}_{pars}.tsv",zip,pars = filtCutFinal_df["PARENTS"],chr = filtCutFinal_df["CHR"],gqcut = filtCutFinal_df["GQ"],dpcut = filtCutFinal_df["DP"]),
        expand("output/LOHAnc/{chr}LOHAnc_GQ{gqcut}_DP{dpcut}_{pars}.tsv",zip, pars = filtCutFinal_df["PARENTS"], chr = filtCutFinal_df["CHR"],gqcut = filtCutFinal_df["GQ"],dpcut = filtCutFinal_df["DP"]),
        "output/LOHRegionsSharedCombined/LOHRegionsSharedCombined.bed",
        "output/LOHRegionsSharedCombined/LOHAncSharedCombined.bed",
        "output/LOHRegionsSharedCombined/LOHSharedGenes.tsv",
        "output/results/LOHSummaryCN.tsv",
        "output/results/LOHAncBinomTest.tsv",
        "output/results/LOHSizeSigDiff.tsv",
        "output/results/CDSIntersectOut.txt",
        "output/results/LOHGenesGOEnrichBP.tsv",
        "output/results/LOHGenesGOEnrichCC.tsv",
        "output/results/LOHGenesGOEnrichMF.tsv",
        "output/results/LOHDStatsExon.tsv",
        "output/results/LOHHStatsExon.tsv",
        "output/results/LOHEStatsExon.tsv",
        "output/results/LOHDStatsNonExon.tsv",
        "output/results/LOHHStatsNonExon.tsv",
        "output/results/LOHEStatsNonExon.tsv",

        
#constrain chromosome wildcard
wildcard_constraints:
    chr="chr[0-9_]+",

#download sra files
rule prefetchSRA:
    priority: 15
    params:
        srx=lambda wc: (samp_df[samp_df['NAME'] == wc.sample]['SRX']).tolist(),
    resources:
        slurm_partition="RM-shared",
        nodes=1,
        runtime=60,
        slurm_extra=lambda wildcards: f"--ntasks-per-node=10 -o scriptOuts/prefetchSRA_{wildcards.sample} -t 3:00:00",
    output:
        "data/rawSeq/{sample}/{sample}.sra",
    threads: 10
    log: 
        "data/rawSeq/{sample}/prefetchSRA_{sample}.log"
    script:
        "scripts/prefetchSRA.sh"
        
#download sra files for hifi samples
rule prefetchSRAHiFi:
    priority: 15
    params:
        srx=lambda wc: (samp_df_hifi[samp_df_hifi['NAME'] == wc.sample_hifi]['SRX']).tolist(),
    resources:
        slurm_partition="RM-shared",
        nodes=1,
        runtime=60,
        slurm_extra=lambda wildcards: f"--ntasks-per-node=10 -o scriptOuts/prefetchSRAHiFi_{wildcards.sample_hifi} -t 2:00:00",
    output:
        "data/rawSeq/{sample_hifi}/{sample_hifi}_HiFi.sra",
    threads: 10
    log: 
        "data/rawSeq/{sample_hifi}/prefetchSRAHiFi_{sample_hifi}.log"
    script:
        "scripts/prefetchSRAHiFi.sh"


#extract fastq.gz from sra files
rule dumpSRA:
    priority: 14
    input:
        "data/rawSeq/{sample}/{sample}.sra",
    params:
        srx=lambda wc: (samp_df[samp_df['NAME'] == wc.sample]['SRX']).tolist(),
    resources:
        slurm_partition="RM-shared",
        nodes=1,
        runtime=360,
        slurm_extra=lambda wildcards: f"--ntasks-per-node=10 -o scriptOuts/dumpSRA_{wildcards.sample} -t 6:00:00",
    output:
        "data/rawSeq/{sample}/{sample}_1.fastq.gz",
        "data/rawSeq/{sample}/{sample}_2.fastq.gz",
    threads: 10
    log: 
        "data/rawSeq/{sample}/dumpSRA_{sample}.log"
    script:
        "scripts/dumpSRA.sh"
        
#extract fastq.gz from sra files for hifi samples
rule dumpSRAHiFi:
    priority: 14
    input:
        "data/rawSeq/{sample_hifi}/{sample_hifi}_HiFi.sra",
    params:
        srx=lambda wc: (samp_df_hifi[samp_df_hifi['NAME'] == wc.sample_hifi]['SRX']).tolist(),
    resources:
        slurm_partition="RM-shared",
        nodes=1,
        runtime=480,
        slurm_extra=lambda wildcards: f"--ntasks-per-node=10 -o scriptOuts/dumpSRAHiFi_{wildcards.sample_hifi} -t 8:00:00",
    output:
        "data/rawSeq/{sample_hifi}/{sample_hifi}_Hifi.fastq.gz",
    threads: 10
    log: 
        "data/rawSeq/{sample_hifi}/dumpSRAHiFi_{sample_hifi}.log"
    script:
        "scripts/dumpSRAHiFi.sh"
        
#trim files
rule trimFastq:
    priority: 13
    input:
        forRead="data/rawSeq/{sample}/{sample}_1.fastq.gz",
        revRead="data/rawSeq/{sample}/{sample}_2.fastq.gz",
    resources:
        slurm_partition="RM-shared",
        nodes=1,
        runtime=90,
        slurm_extra=lambda wildcards: f"--ntasks-per-node=8 -o scriptOuts/trimFastq_{wildcards.sample} -t 3:00:00",
    output:
        "data/trimSeq/{sample}/{sample}_forward_paired.fastq.gz",
        "data/trimSeq/{sample}/{sample}_reverse_paired.fastq.gz",
    threads: 8
    log: 
        "data/trimSeq/{sample}/trimFastq_{sample}.log"
    script:
        "scripts/trimFastq.sh"
 
