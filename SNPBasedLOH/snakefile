    resources:
        slurm_partition="RM-shared",
        nodes=1,
        runtime=360,
        slurm_extra=lambda wildcards: f"--ntasks-per-node=36 -o scriptOuts/alignFastqHiFi_{wildcards.sample_hifi} -t 6:00:00",
