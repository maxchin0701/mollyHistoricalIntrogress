#import pandas 
import pandas as pd

#load in dataframes
#pops=pd.read_csv("data/pops.tsv", sep='\t')
models=pd.read_csv("data/models.tsv",sep='\t')
modelsAll=models
chr_df = pd.read_csv("./data/chrIndex.tsv", sep="\t")
samp_df = pd.read_csv("./data/sampsParHyb.tsv", sep='\t') 
nIter=101

#ruleAll
rule all:
    input:
        expand("data/{modelAM}/iter{iter}/{modelAM}/{modelAM}_maxL.par",modelAM=models["MODELS"],iter=list(range(1,101))),
        expand("data/{modelAM}/iter{iter}/{modelAM}/{modelAM}.bestlhoods",modelAM=models["MODELS"],iter=list(range(1,101))),
        expand("data/{model}/bestIter/{model}.lhoods",model=modelsAll["MODELS"]),
        expand("data/{model}/bestIter/{model}.AIC",model=modelsAll["MODELS"]),

rule subsampleFilterVCF:
    priority: 13
    input:
        "data/hapCalls/{chr}CombinedParHyb.vcf.gz"        
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=4G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/subsampleFilterVCF_{wildcards.chr} -t 1:00:00 --open-mode=truncate",
    output:
        "data/hapCallParHybs/{chr}.vcf.gz"
    threads: 4
    log:
        "data/hapCallParHybs/subsampleFilterVCF_{chr}.log"
    script:
        "scripts/subsetVCFParHyb.sh"
        
#subsample and filter vcf
rule genRefPanel:
    priority: 12
    input:
        "data/hapCallParHybs/{chr}.vcf.gz"        
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=4G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/genRefPanel_{wildcards.chr} -t 1:00:00 --open-mode=truncate",
    output:
        "data/refPanel/{chr}WhatshapRefPanel.vcf.gz"
    threads: 4
    log:
        "data/refPanel/genRefPanel_{chr}.log"
    script:
        "scripts/genWhatshapRefPanel.sh"

#read based phasing with whatshap
rule phaseSamps:
    priority: 11
    input:
        "data/hapCallParHybs/{chr}.vcf.gz",  
        "data/refPanel/{chr}WhatshapRefPanel.vcf.gz"
    params:
        ref="data/refGenome/PForHapMex.fasta",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=240,
        mem_mb=16000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=8 --mem=16G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/phaseSamps_{wildcards.chr}_{wildcards.samp} -t 4:00:00 --open-mode=truncate",
    output:
        "data/phasedHapsWhatshap/{chr}_{samp}Phased.vcf.gz",
        "data/phasedHapsWhatshap/{chr}_{samp}Phased.vcf.gz.tbi"
    log:
        "data/phasedHapsWhatshap/phaseSamps_{chr}_{samp}.log"
    script:
        "scripts/phaseHapsWhatsHap.sh"
        
#merge hybrids and parents separately
rule mergeHybPars:
    priority: 10
    input:
        expand("data/phasedHapsWhatshap/{{chr}}_{samp}Phased.vcf.gz",samp = samp_df["SAMPS"]),  
        expand("data/phasedHapsWhatshap/{{chr}}_{samp}Phased.vcf.gz.tbi",samp = samp_df["SAMPS"])
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=1 --mem=4G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/mergeHybPars_{wildcards.chr} -t 1:00:00 --open-mode=truncate",
    output:
        "data/phasedHapsWhatshap/{chr}Phased.vcf.gz"
    threads: 1
    log:
        "data/phasedHapsWhatshap/mergeHybPars_{chr}.log"
    script:
        "scripts/mergeHybPars.sh"

#filter vcf
rule filtPhasedVCF:
    priority: 9
    input:
        "data/phasedHapsWhatshap/{chr}Phased.vcf.gz"
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=1 --mem=4G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/filtPhasedVCF_{wildcards.chr} -t 1:00:00 --open-mode=truncate",
    output:
        "data/phasedHapsWhatshap/{chr}PhasedFilt.vcf.gz"
    threads: 1
    log:
        "data/phasedHapsWhatshap/filtPhasedVCF_{chr}.log"
    script:
        "scripts/filtPhasedVCF.sh"

#combine chromosome VCF files
rule combineChrVCF:
    priority: 8
    input:
        "data/chrHaps.list",
        "data/refGenome/PForHapMex.dict",
        "data/samps.args",
        expand("data/phasedHapsWhatshap/{chr}PhasedFilt.vcf.gz",chr = chr_df["CHR"])
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=300,
        mem_mb=20000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=10 --mem=20G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/combineChrVCF -t 5:00:00 --open-mode=truncate",
    output:
        "data/combinedHap/chrAllCombinedFilt.vcf.gz",
        "data/combinedHap/chrSymParHybCombinedFilt.vcf.gz"
    threads: 10
    log: 
        "data/combinedHap/combineChrVCF.log"
    script:
        "scripts/combineChrVCF.sh"

#split vcf
rule splitHaps:
    priority: 7
    input:
        "data/combinedHap/chrSymParHybCombinedFilt.vcf.gz"
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=120,
        mem_mb=20000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=8 --mem=20G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/splitHaps -t 2:00:00 --open-mode=truncate",
    output:
        "data/splitHap/splitParHyb.vcf.gz"
    threads: 10
    log: 
        "data/splitHap/splitHaps.log"
    script:
        "scripts/splitHaps.sh"

#get partitions
rule getPartitions:
    priority: 6
    input:
        "data/splitHap/splitParHyb.vcf.gz"
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=20000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=4G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/getPartitions_{wildcards.iter} -t 1:00:00 --open-mode=truncate",
    output:
        "data/splitHapPartitions/splitParHyb_{iter}.vcf.gz"
    threads: 4
    log:
        "data/splitHapPartitions/getPartitions_{iter}"
    script:
        "scripts/getPartitions.sh"

rule getSFS:
    priority: 5
    input:
        inVCF="data/splitHapPartitions/splitParHyb_{iter}.vcf.gz",
        pops="data/pops.tsv",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=360,
        mem_mb=8000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=8G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/getSFS_{wildcards.iter} -t 6:00:00 --open-mode=truncate",
    output:
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop1_0.obs",
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop2_0.obs",
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop2_1.obs",
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop3_0.obs",
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop3_1.obs",
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop3_2.obs"
    threads: 4
    log: 
        "data/sfs/getSFS_{iter}.log"
    script:
        "scripts/getSFS.sh"
        
rule runFSCInitial:
    priority: 4
    input:
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop1_0.obs",
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop2_0.obs",
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop2_1.obs",
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop3_0.obs",
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop3_1.obs",
        "data/sfs/iter{iter}/demModelMolly_jointMAFpop3_2.obs",
        "data/{modelAM}/{modelAM}.tpl",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=20160,
        mem_mb=8000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=8G -o scriptOuts/runFSCInitial_{wildcards.modelAM}_{wildcards.iter} -t 7-00:00:00 --open-mode=truncate",
    output:
        "data/{modelAM}/iter{iter}/{modelAM}/{modelAM}_maxL.par",
        "data/{modelAM}/iter{iter}/{modelAM}/{modelAM}.bestlhoods",
    threads: 4
    retries: 5
    log:
        "data/{modelAM}/iter{iter}/runFSCInitial_{modelAM}_{iter}.log"
    script:
        "scripts/runFSCInitial.sh"

rule getBestRun:
    priority: 3
    input:
        expand("data/{model}/iter{iter}/{model}/{model}_maxL.par",model=modelsAll["MODELS"],iter=list(range(1,101))),
        expand("data/{model}/iter{iter}/{model}/{model}.bestlhoods",model=modelsAll["MODELS"],iter=list(range(1,101))),
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=1 --mem=4G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/getBestRun -t 1:00:00  --open-mode=truncate",
    output:
        expand("data/{model}/bestIter/{model}/{model}_maxL.par",model=modelsAll["MODELS"]),
        expand("data/{model}/bestIter/{model}/{model}.bestlhoods",model=modelsAll["MODELS"]),
        expand("data/{model}/bestIter/{model}_temp.lhoods",model=modelsAll["MODELS"]),
    threads: 1
    log:
        "data/getBestRun.log"
    script:
        "scripts/saveBestModel.sh"

rule runFSCLhood:
    priority: 2
    input:
        "data/{model}/bestIter/{model}/{model}_maxL.par",
        "data/{model}/bestIter/{model}/{model}.bestlhoods",
        "data/{model}/bestIter/{model}_temp.lhoods",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=600,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=8G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/runFSCLhood_{wildcards.model} -t 10:00:00  --open-mode=truncate",
    output:
        "data/{model}/bestIter/{model}.lhoods"
    threads: 4
    log:
        "data/{model}/bestIter/runFSCLhood.log"
    script:
        "scripts/runFSCLhood.sh"
        
rule getAIC:
    priority: 1
    input:
        "data/{model}/bestIter/{model}/{model}.bestlhoods",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=1000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=1G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/getAIC_{wildcards.model} -t 1:00:00 --open-mode=truncate",
    output:
        "data/{model}/bestIter/{model}.AIC"
    threads: 4
    log:
        "data/{model}/bestIter/getAIC_{model}.log"
    script:
        "scripts/calculateAIC.sh"

        
        
        

