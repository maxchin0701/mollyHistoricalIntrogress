        "data/sfs/demModelMolly_jointMAFpop2_0.obs",
        "data/sfs/demModelMolly_jointMAFpop2_1.obs",
        "data/sfs/demModelMolly_jointMAFpop3_0.obs",
        "data/sfs/demModelMolly_jointMAFpop3_1.obs",
        "data/sfs/demModelMolly_jointMAFpop3_2.obs",
        "data/{modelAM}/{modelAM}.tpl",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=1 --mem=4G -o scriptOuts/moveSFS_{wildcards.modelAM} -t 1:00:00 --open-mode=truncate",
    output:
