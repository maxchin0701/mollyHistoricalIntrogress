        "data/{modelAM}/{modelAM}_jointMAFpop3_1.obs",
        "data/{modelAM}/{modelAM}_jointMAFpop3_2.obs",
    threads: 1
    log:
        "data/{modelAM}/moveSFS_{modelAM}.log"
