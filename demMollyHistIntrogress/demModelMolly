rule runFSCInitial:
    priority: 4
    input:
        "data/{modelAM}/{modelAM}_jointMAFpop1_0.obs",
        "data/{modelAM}/{modelAM}_jointMAFpop2_0.obs",
        "data/{modelAM}/{modelAM}_jointMAFpop2_1.obs",
        "data/{modelAM}/{modelAM}_jointMAFpop3_0.obs",
        "data/{modelAM}/{modelAM}_jointMAFpop3_1.obs",
        "data/{modelAM}/{modelAM}_jointMAFpop3_2.obs",
        "data/{modelAM}/{modelAM}.tpl",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=10080,
        mem_mb=8000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=8G -o scriptOuts/runFSCInitial_{wildcards.modelAM}_{wildcards.iter} -t 7-00:00:00 --open-mode=truncate",
