#import pandas 
import pandas as pd

#load in dataframes
#pops=pd.read_csv("data/pops.tsv", sep='\t')
models=pd.read_csv("data/models.tsv",sep='\t')
modelsNoAM=pd.read_csv("data/modelsNoAM.tsv",sep='\t')
modelsAll=pd.concat([models,modelsNoAM],axis=0)
chr_df = pd.read_csv("./data/chrIndex.tsv", sep="\t")
samp_df = pd.read_csv("./data/sampsParHyb.tsv", sep='\t') 
nIter=101

#ruleAll
rule all:
    input:
        expand("data/{modelAM}/iter{iter}/{modelAM}/{modelAM}_maxL.par",modelAM=models["MODELS"],iter=list(range(1,101))),
        expand("data/{modelAM}/iter{iter}/{modelAM}/{modelAM}.bestlhoods",modelAM=models["MODELS"],iter=list(range(1,101))),
        expand("data/{modelNoAM}/iter{iter}/{modelNoAM}/{modelNoAM}_maxL.par",modelNoAM=modelsNoAM["MODELS"],iter=list(range(1,101))),
        expand("data/{modelNoAM}/iter{iter}/{modelNoAM}/{modelNoAM}.bestlhoods",modelNoAM=modelsNoAM["MODELS"],iter=list(range(1,101))),
        expand("data/{model}/bestIter/{model}.lhoods",model=modelsAll["MODELS"]),
        expand("data/{model}/bestIter/{model}.AIC",model=modelsAll["MODELS"]),

#constrain wildcards
wildcard_constraints:
    modelNoAM=".*NoAM.*",
    modelAM="(?!.*NoAM).*"

rule subsampleFilterVCF:
    priority: 13
    input:
        "data/hapCalls/{chr}CombinedParHyb.vcf.gz",        
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=4G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/subsampleFilterVCF_{wildcards.chr} -t 1:00:00 --open-mode=truncate",
    output:
        "data/hapCallParHybs/{chr}.vcf.gz",
    threads: 4
    log:
        "data/hapCallParHybs/subsampleFilterVCF_{chr}.log"
    script:
        "scripts/subsetVCFParHyb.sh"
        
#subsample and filter vcf
rule genRefPanel:
    priority: 12
    input:
        "data/hapCallParHybs/{chr}.vcf.gz",        
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=4G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/genRefPanel_{wildcards.chr} -t 1:00:00 --open-mode=truncate",
    output:
        "data/refPanel/{chr}WhatshapRefPanel.vcf.gz",
    threads: 4
    log:
        "data/refPanel/genRefPanel_{chr}.log"
    script:
        "scripts/genWhatshapRefPanel.sh"

#read based phasing with whatshap
rule phaseSamps:
    priority: 11
    input:
        "data/hapCallParHybs/{chr}.vcf.gz",  
        "data/refPanel/{chr}WhatshapRefPanel.vcf.gz",
    params:
        ref="data/refGenome/PForHapMex.fasta"
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=240,
        mem_mb=16000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=8 --mem=16G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/phaseSamps_{wildcards.chr}_{wildcards.samp} -t 4:00:00 --open-mode=truncate",
    output:
        "data/phasedHapsWhatshap/{chr}_{samp}Phased.vcf.gz",
        "data/phasedHapsWhatshap/{chr}_{samp}Phased.vcf.gz.tbi",
    log:
        "data/phasedHapsWhatshap/phaseSamps_{chr}_{samp}.log"
    script:
        "scripts/phaseHapsWhatsHap.sh"
        
#merge hybrids and parents separately
rule mergeHybPars:
    priority: 10
    input:
        expand("data/phasedHapsWhatshap/{{chr}}_{samp}Phased.vcf.gz",samp = samp_df["SAMPS"]),  
        expand("data/phasedHapsWhatshap/{{chr}}_{samp}Phased.vcf.gz.tbi",samp = samp_df["SAMPS"]),  
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=1 --mem=4G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/mergeHybPars_{wildcards.chr} -t 1:00:00 --open-mode=truncate",
    output:
        "data/phasedHapsWhatshap/{chr}Phased.vcf.gz",
    threads: 1
    log:
        "data/phasedHapsWhatshap/mergeHybPars_{chr}.log"
    script:
        "scripts/mergeHybPars.sh"

#filter vcf
rule filtPhasedVCF:
    priority: 9
    input:
        "data/phasedHapsWhatshap/{chr}Phased.vcf.gz",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=60,
        mem_mb=4000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=1 --mem=4G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/filtPhasedVCF_{wildcards.chr} -t 1:00:00 --open-mode=truncate",
    output:
        "data/phasedHapsWhatshap/{chr}PhasedFilt.vcf.gz",
    threads: 1
    log:
        "data/phasedHapsWhatshap/filtPhasedVCF_{chr}.log"
    script:
        "scripts/filtPhasedVCF.sh"

#combine chromosome VCF files
rule combineChrVCF:
    priority: 8
    input:
        "data/chrHaps.list",
        "data/refGenome/PForHapMex.dict",
        "data/samps.args",
        expand("data/phasedHapsWhatshap/{chr}PhasedFilt.vcf.gz",chr = chr_df["CHR"]),  
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=300,
        mem_mb=20000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=10 --mem=20G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/combineChrVCF -t 5:00:00 --open-mode=truncate",
    output:
        "data/combinedHap/chrAllCombinedFilt.vcf.gz",
        "data/combinedHap/chrSymParHybCombinedFilt.vcf.gz",
    threads: 10
    log: 
        "data/combinedHap/combineChrVCF.log"
    script:
        "scripts/combineChrVCF.sh"

#split vcf
rule splitHaps:
    priority: 7
    input:
        "data/combinedHap/chrSymParHybCombinedFilt.vcf.gz",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=120,
        mem_mb=20000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=8 --mem=20G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/splitHaps -t 2:00:00 --open-mode=truncate",
    output:
        "data/splitHap/splitParHyb.vcf.gz",
    threads: 10
    log: 
        "data/splitHap/splitHaps.log"
    script:
        "scripts/splitHaps.sh"

#combine chromosome VCF no AM
rule combineChrVCFNoAM:
    priority: 8
    input:
        "data/chrHaps.list",
        "data/refGenome/PForHapMex.dict",
        "data/sampsNoAM.args",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=300,
        slurm_extra=lambda wildcards: f"--ntasks-per-node=10 -o scriptOuts/combineChrVCF -t 5:00:00",
    output:
        "data/combinedHap/chrAllCombinedFilt.vcf.gz",
        "data/combinedHap/chrSymParCombinedFilt.vcf.gz",
    threads: 10
    log: 
        "data/combinedHap/combineChrVCF.log"
    script:
        "scripts/combineChrVCFNoAM.sh"

rule getSFS:
    priority: 6
    input:
        inVCF="data/splitHap/splitParHyb.vcf.gz",
        pops="data/pops.tsv",
    resources:
        slurm_partition="low",
        nodes=1,
        runtime=360,
        mem_mb=8000,
        slurm_extra=lambda wildcards: f"-D /group/awhitehegrp/max/demMollyHistIntrogress --ntasks-per-node=4 --mem=8G -o /group/awhitehegrp/max/demMollyHistIntrogress/scriptOuts/getSFS -t 6:00:00 --open-mode=truncate",
    output:
        "data/sfs/demModelMolly_jointMAFpop1_0.obs",
        "data/sfs/demModelMolly_jointMAFpop2_0.obs",
        "data/sfs/demModelMolly_jointMAFpop2_1.obs",
        "data/sfs/demModelMolly_jointMAFpop3_0.obs",
        "data/sfs/demModelMolly_jointMAFpop3_1.obs",
        "data/sfs/demModelMolly_jointMAFpop3_2.obs",
    threads: 10
    log: 
        "data/sfs/getSFS.log"
    script:
        "scripts/getSFS.sh"

rule getSFSNoAM:
    priority: 6
    input:
        inVCF="data/combinedHap/chrSymParCombinedFilt.vcf.gz",
        pops="data/popsNoAM.tsv",
    params:
        nSampPop0=8,
        nSampPop1=4,
    resources:
        slurm_partition="RM-shared",
        nodes=1,
        runtime=60,
        slurm_extra=lambda wildcards: f"--ntasks-per-node=10 -o scriptOuts/getSFSNoAM -t 1:00:00",
    output:
        "data/sfsNoAM/fastsimcoal2/demModelMolly_jointMAFpop1_0.obs",
    threads: 10
    log: 
        "data/sfsNoAM/getSFSNoAM.log"
    script:
        "scripts/getSFSNoAM.sh"

rule moveSFS:
    priority: 5
    input:
