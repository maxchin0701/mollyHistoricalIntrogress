rule getBestRun:
    priority: 3
    input:
        expand("data/{{model}}/iter{iter}/{{model}}/{{model}}_maxL.par",iter=list(range(1,101))),
        expand("data/{{model}}/iter{iter}/{{model}}/{{model}}.bestlhoods",iter=list(range(1,101))),
    resources:
        slurm_partition="RM-shared",
        nodes=1,
        runtime=60,
        slurm_extra=lambda wildcards: f"--ntasks-per-node=1 -o scriptOuts/getBestRun_{wildcards.model} -t 1:00:00",
    output:
        "data/{model}/bestIter/{model}/{model}_maxL.par",
        "data/{model}/bestIter/{model}/{model}.bestlhoods",
        "data/{model}/bestIter/{model}_temp.lhoods",
    threads: 1
    log:
        "data/{model}/bestIter/getBestRun.log"
    script:
        "scripts/saveBestModel.sh"

